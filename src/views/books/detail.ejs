<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <%- include('../partials/flash') %>

    <a href="/books" class="inline-flex items-center gap-2 text-sm font-semibold text-primary-600 hover:text-primary-700 hover:gap-3 transition-all duration-300 mb-8">
        <i class="fas fa-arrow-left"></i> Quay lại thư viện
    </a>

    <div class="bg-white rounded-3xl shadow-soft-xl p-6 sm:p-10 border border-gray-100/50">
        <div class="flex flex-col md:flex-row gap-10">
            <!-- Ảnh bìa -->
            <div class="md:w-1/3">
                <div class="aspect-[3/4] bg-gray-100 rounded-2xl overflow-hidden shadow-soft-lg">
                    <% if (book.cover_image) { %>
                        <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700">
                    <% } else { %>
                        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-400 to-primary-600">
                            <i class="fas fa-book text-white text-6xl"></i>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Thông tin sách -->
            <div class="md:w-2/3">
                <div class="mb-4">
                    <span class="inline-flex items-center text-xs font-bold px-3.5 py-1.5 rounded-xl uppercase
                        <%= book.file_type === 'pdf' ? 'bg-red-50 text-red-600' : 'bg-emerald-50 text-emerald-600' %>">
                        <i class="fas <%= book.file_type === 'pdf' ? 'fa-file-pdf' : 'fa-book' %> mr-1.5"></i>
                        <%= book.file_type %>
                    </span>
                </div>

                <h1 class="text-3xl sm:text-4xl font-extrabold font-headline text-gray-800 mb-6"><%= book.title %></h1>

                <div class="space-y-4 mb-8">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-pen-nib text-gray-400 text-sm"></i>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 font-medium">Tác giả</p>
                            <p class="text-sm font-semibold text-gray-700"><%= book.author %></p>
                        </div>
                    </div>
                    <% if (book.category_name) { %>
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-folder text-gray-400 text-sm"></i>
                            </div>
                            <div>
                                <p class="text-xs text-gray-400 font-medium">Thể loại</p>
                                <p class="text-sm font-semibold text-gray-700"><%= book.category_name %></p>
                            </div>
                        </div>
                    <% } %>
                    <% if (book.uploader_name) { %>
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-upload text-gray-400 text-sm"></i>
                            </div>
                            <div>
                                <p class="text-xs text-gray-400 font-medium">Người tải</p>
                                <p class="text-sm font-semibold text-gray-700"><%= book.uploader_name %></p>
                            </div>
                        </div>
                    <% } %>
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-calendar text-gray-400 text-sm"></i>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 font-medium">Ngày thêm</p>
                            <p class="text-sm font-semibold text-gray-700"><%= new Date(book.created_at).toLocaleDateString('vi-VN') %></p>
                        </div>
                    </div>
                </div>

                <% if (book.description) { %>
                    <div class="mb-8">
                        <h3 class="text-sm font-bold font-headline text-gray-800 uppercase tracking-wider mb-3">Mô tả</h3>
                        <p class="text-gray-500 leading-relaxed"><%= book.description %></p>
                    </div>
                <% } %>

                <!-- Tiến trình đọc -->
                <% if (progress) { %>
                    <div class="bg-primary-50 border border-primary-100 rounded-2xl p-5 mb-8 flex items-center gap-4">
                        <div class="w-10 h-10 rounded-xl bg-primary-100 flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-bookmark text-primary-600"></i>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-primary-700">
                                Đã đọc đến trang <strong><%= progress.current_page %></strong>
                            </p>
                            <p class="text-xs text-primary-500">Lần đọc cuối: <%= new Date(progress.last_read_at).toLocaleDateString('vi-VN') %></p>
                        </div>
                    </div>
                <% } %>

                <!-- Nút đọc sách -->
                <a href="/books/<%= book.id %>/read" class="btn-primary inline-flex items-center text-lg py-4 px-10">
                    <i class="fas fa-book-reader mr-2"></i>
                    <%= progress ? 'Tiếp tục đọc' : 'Bắt đầu đọc' %>
                </a>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>