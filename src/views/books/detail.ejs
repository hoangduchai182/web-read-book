<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="max-w-5xl mx-auto px-4 py-8">
    <%- include('../partials/flash') %>

    <a href="/books" class="inline-flex items-center text-primary-600 hover:text-primary-700 mb-6">
        <i class="fas fa-arrow-left mr-2"></i> Quay lại thư viện
    </a>

    <div class="card p-6 md:p-8">
        <div class="flex flex-col md:flex-row gap-8">
            <!-- Ảnh bìa -->
            <div class="md:w-1/3">
                <div class="aspect-[3/4] bg-gray-200 rounded-lg overflow-hidden shadow-lg">
                    <% if (book.cover_image) { %>
                        <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="w-full h-full object-cover">
                    <% } else { %>
                        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-400 to-primary-600">
                            <i class="fas fa-book text-white text-6xl"></i>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Thông tin sách -->
            <div class="md:w-2/3">
                <div class="flex items-start justify-between mb-2">
                    <span class="inline-block text-xs font-bold px-3 py-1 rounded-full uppercase
                        <%= book.file_type === 'pdf' ? 'bg-red-100 text-red-600' : 'bg-green-100 text-green-600' %>">
                        <i class="fas <%= book.file_type === 'pdf' ? 'fa-file-pdf' : 'fa-book' %> mr-1"></i>
                        <%= book.file_type %>
                    </span>
                </div>

                <h1 class="text-3xl font-bold text-gray-800 mb-3"><%= book.title %></h1>

                <div class="space-y-3 mb-6">
                    <p class="text-gray-600">
                        <i class="fas fa-pen-nib text-gray-400 w-5 mr-2"></i>
                        <span class="font-medium">Tác giả:</span> <%= book.author %>
                    </p>
                    <% if (book.category_name) { %>
                        <p class="text-gray-600">
                            <i class="fas fa-folder text-gray-400 w-5 mr-2"></i>
                            <span class="font-medium">Thể loại:</span> <%= book.category_name %>
                        </p>
                    <% } %>
                    <% if (book.uploader_name) { %>
                        <p class="text-gray-600">
                            <i class="fas fa-upload text-gray-400 w-5 mr-2"></i>
                            <span class="font-medium">Người tải:</span> <%= book.uploader_name %>
                        </p>
                    <% } %>
                    <p class="text-gray-600">
                        <i class="fas fa-calendar text-gray-400 w-5 mr-2"></i>
                        <span class="font-medium">Ngày thêm:</span> <%= new Date(book.created_at).toLocaleDateString('vi-VN') %>
                    </p>
                </div>

                <% if (book.description) { %>
                    <div class="mb-6">
                        <h3 class="font-semibold text-gray-800 mb-2">Mô tả</h3>
                        <p class="text-gray-600 leading-relaxed"><%= book.description %></p>
                    </div>
                <% } %>

                <!-- Tiến trình đọc -->
                <% if (progress) { %>
                    <div class="bg-primary-50 border border-primary-200 rounded-lg p-4 mb-6">
                        <p class="text-primary-700">
                            <i class="fas fa-bookmark mr-2"></i>
                            Bạn đã đọc đến trang <strong><%= progress.current_page %></strong>
                            - Lần đọc cuối: <%= new Date(progress.last_read_at).toLocaleDateString('vi-VN') %>
                        </p>
                    </div>
                <% } %>

                <!-- Nút đọc sách -->
                <a href="/books/<%= book.id %>/read" class="btn-primary inline-flex items-center text-lg py-3 px-8">
                    <i class="fas fa-book-reader mr-2"></i>
                    <%= progress ? 'Tiếp tục đọc' : 'Bắt đầu đọc' %>
                </a>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>