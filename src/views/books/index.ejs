<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <!-- Page Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-10 gap-4 reveal reveal-left">
        <div>
            <p class="text-sm font-bold text-primary-600 uppercase tracking-[0.2em] mb-2">Khám phá</p>
            <h1 class="text-4xl font-extrabold font-headline text-gray-800">
                Thư viện sách
            </h1>
        </div>
    </div>

    <%- include('../partials/flash') %>

        <!-- Search & Filter -->
    <div class="bg-white rounded-2xl shadow-soft p-5 mb-10 border border-gray-100/50 reveal reveal-up" style="animation-delay: 0.15s">
        <form action="/books" method="GET" class="flex flex-col sm:flex-row gap-4">
            <div class="flex-1">
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400">
                        <i class="fas fa-search text-sm"></i>
                    </span>
                    <input type="text" name="search" value="<%= search %>" class="input-field pl-11" placeholder="Tìm theo tên sách hoặc tác giả...">
                </div>
            </div>
            <div class="sm:w-52">
                <select name="category" class="input-field">
                    <option value="">Tất cả thể loại</option>
                    <% categories.forEach(function(cat) { %>
                        <option value="<%= cat.id %>" <%= categoryId == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                    <% }); %>
                </select>
            </div>
            <button type="submit" class="btn-primary">
                <i class="fas fa-search mr-1.5"></i> Tìm kiếm
            </button>
        </form>
    </div>

    <!-- Book Grid -->
    <% if (books.length > 0) { %>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
            <% books.forEach(function(book) { %>
                                <a href="/books/<%= book.id %>" class="group reveal reveal-up" style="animation-delay: <%= 0.08 * (books.indexOf(book) % 6) %>s">
                    <div class="card overflow-hidden">
                        <div class="aspect-[3/4] bg-gray-100 relative overflow-hidden">
                                                        <% if (book.cover_image) { %>
                                <div class="skeleton absolute inset-0"></div>
                                <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="book-cover-img w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" style="opacity:0;transition:opacity 0.4s ease">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-400 to-primary-600">
                                    <i class="fas fa-book text-white text-4xl"></i>
                                </div>
                            <% } %>
                            <div class="absolute top-2.5 right-2.5">
                                <span class="bg-white/90 backdrop-blur-sm text-xs font-bold px-2.5 py-1 rounded-lg uppercase
                                    <%= book.file_type === 'pdf' ? 'text-red-600' : 'text-emerald-600' %>">
                                    <%= book.file_type %>
                                </span>
                            </div>
                                                        <!-- Hover overlay -->
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-3">
                                <span class="text-white text-xs font-semibold"><i class="fas fa-book-reader mr-1"></i> Đọc ngay</span>
                            </div>
                        </div>
                        <div class="p-3">
                            <h3 class="font-bold text-sm text-gray-800 truncate group-hover:text-primary-600 transition-colors" title="<%= book.title %>"><%= book.title %></h3>
                            <p class="text-xs text-gray-400 truncate mt-1"><%= book.author %></p>
                            <div class="flex items-center justify-between mt-2">
                                <% if (book.category_name) { %>
                                    <span class="inline-block bg-primary-50 text-primary-700 text-xs font-semibold px-2.5 py-0.5 rounded-lg"><%= book.category_name %></span>
                                <% } else { %>
                                    <span></span>
                                <% } %>
                                <span class="text-xs text-gray-400"><i class="fas fa-eye mr-1"></i> <%= book.views || 0 %></span>
                            </div>
                        </div>
                    </div>
                </a>
            <% }); %>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="flex justify-center mt-12">
                <nav class="inline-flex items-center gap-1.5 bg-white rounded-2xl shadow-soft p-2 border border-gray-100/50">
                    <% if (currentPage > 1) { %>
                        <a href="/books?page=<%= currentPage - 1 %>&search=<%= search %>&category=<%= categoryId %>"
                           class="w-10 h-10 flex items-center justify-center rounded-xl text-gray-500 hover:bg-primary-50 hover:text-primary-600 transition-all duration-300">
                            <i class="fas fa-chevron-left text-sm"></i>
                        </a>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="/books?page=<%= i %>&search=<%= search %>&category=<%= categoryId %>"
                           class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-semibold transition-all duration-300
                           <%= i === currentPage ? 'bg-gradient-to-r from-primary-600 to-primary-500 text-white shadow-glow' : 'text-gray-600 hover:bg-primary-50 hover:text-primary-600' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <a href="/books?page=<%= currentPage + 1 %>&search=<%= search %>&category=<%= categoryId %>"
                           class="w-10 h-10 flex items-center justify-center rounded-xl text-gray-500 hover:bg-primary-50 hover:text-primary-600 transition-all duration-300">
                            <i class="fas fa-chevron-right text-sm"></i>
                        </a>
                    <% } %>
                </nav>
            </div>
        <% } %>
    <% } else { %>
                <div class="text-center py-24 reveal reveal-fade">
            <div class="w-20 h-20 bg-gray-100 rounded-3xl flex items-center justify-center mx-auto mb-6">
                <i class="fas fa-book-open text-gray-300 text-3xl"></i>
            </div>
            <h3 class="text-xl font-bold font-headline text-gray-500">Không tìm thấy sách nào</h3>
            <p class="text-gray-400 mt-2">Hãy thử tìm kiếm với từ khóa khác</p>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>