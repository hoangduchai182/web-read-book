<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Hero Section -->
<section class="relative overflow-hidden text-white" style="background: linear-gradient(135deg, #1e1b4b 0%, #4f46e5 40%, #7c3aed 70%, #a855f7 100%);">
    <!-- Decorative blobs -->
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-purple-400/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] bg-indigo-300/15 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-violet-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28 sm:py-40 relative z-10">
        <div class="text-center max-w-3xl mx-auto">
                        <div class="inline-flex items-center px-5 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-xs font-bold tracking-widest uppercase mb-8 hover:bg-white/20 transition-all duration-300 cursor-default reveal reveal-down" style="animation-delay: 0.1s">
                <i class="fas fa-sparkles mr-2 text-yellow-300"></i> Nền tảng đọc sách trực tuyến
            </div>
            <h1 class="text-5xl sm:text-7xl font-extrabold tracking-tight font-headline leading-[1.1] mb-8 reveal reveal-up" style="animation-delay: 0.2s">
                Đọc sách
                <span class="block text-transparent bg-clip-text bg-gradient-to-r from-purple-200 via-pink-200 to-white">mọi lúc, mọi nơi</span>
            </h1>
            <p class="text-lg sm:text-xl text-purple-100/80 mb-10 max-w-2xl mx-auto leading-relaxed reveal reveal-up" style="animation-delay: 0.4s">
                Khám phá kho tàng sách phong phú với hàng ngàn đầu sách thuộc nhiều thể loại.
                Hỗ trợ đọc PDF và EPUB trực tuyến hoàn toàn miễn phí.
            </p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-up" style="animation-delay: 0.6s">
                <% if (typeof user !== 'undefined' && user) { %>
                                        <a href="/books" class="group px-8 py-4 bg-white text-primary-700 font-bold rounded-2xl shadow-soft-xl hover:shadow-glow hover:scale-105 hover:-translate-y-1 transition-all duration-300 text-lg">
                        <i class="fas fa-book-reader mr-2 group-hover:animate-bounce"></i> Vào thư viện
                    </a>
                <% } else { %>
                                        <a href="/auth/register" class="group px-8 py-4 bg-white text-primary-700 font-bold rounded-2xl shadow-soft-xl hover:shadow-glow hover:scale-105 hover:-translate-y-1 transition-all duration-300 text-lg">
                        <i class="fas fa-user-plus mr-2 group-hover:rotate-12 transition-transform duration-300"></i> Đăng ký miễn phí
                    </a>
                    <a href="/auth/login" class="group px-8 py-4 border-2 border-white/30 text-white font-bold rounded-2xl hover:bg-white hover:text-primary-700 hover:scale-105 hover:-translate-y-1 hover:border-white transition-all duration-300 text-lg backdrop-blur-sm">
                        <i class="fas fa-sign-in-alt mr-2"></i> Đăng nhập
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="relative -mt-12 z-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto grid grid-cols-3 gap-4 sm:gap-6">
                                <div class="group bg-white/90 backdrop-blur-xl rounded-2xl shadow-soft-lg p-6 text-center border border-white/50 hover:shadow-glow hover:-translate-y-2 hover:bg-white transition-all duration-500 cursor-default reveal reveal-up" style="animation-delay: 0.1s">
            <div class="w-12 h-12 bg-gradient-to-br from-primary-100 to-primary-50 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
                <i class="fas fa-book text-primary-600 text-lg"></i>
            </div>
            <p class="text-3xl sm:text-4xl font-extrabold font-headline text-primary-600 group-hover:text-primary-700 transition-colors">500+</p>
            <p class="text-sm text-gray-500 font-medium mt-1">Đầu sách</p>
        </div>
        <div class="group bg-white/90 backdrop-blur-xl rounded-2xl shadow-soft-lg p-6 text-center border border-white/50 hover:shadow-glow hover:-translate-y-2 hover:bg-white transition-all duration-500 cursor-default reveal reveal-up" style="animation-delay: 0.3s">
            <div class="w-12 h-12 bg-gradient-to-br from-emerald-100 to-emerald-50 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
                <i class="fas fa-file-alt text-emerald-600 text-lg"></i>
            </div>
            <p class="text-3xl sm:text-4xl font-extrabold font-headline text-primary-600 group-hover:text-primary-700 transition-colors">PDF & EPUB</p>
            <p class="text-sm text-gray-500 font-medium mt-1">Định dạng</p>
        </div>
        <div class="group bg-white/90 backdrop-blur-xl rounded-2xl shadow-soft-lg p-6 text-center border border-white/50 hover:shadow-glow hover:-translate-y-2 hover:bg-white transition-all duration-500 cursor-default reveal reveal-up" style="animation-delay: 0.5s">
            <div class="w-12 h-12 bg-gradient-to-br from-violet-100 to-violet-50 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
                <i class="fas fa-heart text-violet-600 text-lg"></i>
            </div>
            <p class="text-3xl sm:text-4xl font-extrabold font-headline text-primary-600 group-hover:text-primary-700 transition-colors">100%</p>
            <p class="text-sm text-gray-500 font-medium mt-1">Miễn phí</p>
        </div>
    </div>
</section>

<!-- Features -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
        <div class="text-center mb-16 reveal reveal-up">
        <p class="text-sm font-bold text-primary-600 uppercase tracking-[0.2em] mb-3">Tính năng</p>
        <h2 class="text-4xl font-extrabold font-headline text-gray-800">Trải nghiệm đọc hiện đại</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="card p-8 text-center group hover:shadow-glow hover:-translate-y-2 transition-all duration-500 border border-transparent hover:border-primary-100 reveal reveal-left" style="animation-delay: 0.1s">
            <div class="w-16 h-16 bg-gradient-to-br from-primary-100 to-primary-50 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 group-hover:rotate-6 group-hover:shadow-lg transition-all duration-500">
                <i class="fas fa-file-pdf text-primary-600 text-2xl group-hover:text-primary-700 transition-colors"></i>
            </div>
            <h3 class="text-xl font-bold font-headline mb-3 text-gray-800 group-hover:text-primary-600 transition-colors duration-300">Đọc PDF trực tuyến</h3>
            <p class="text-gray-500 leading-relaxed">Trình đọc PDF tích hợp mạnh mẽ, hỗ trợ zoom, điều hướng trang và lưu tiến trình.</p>
            <div class="mt-5 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-500">
                <span class="text-primary-600 text-sm font-semibold">Tìm hiểu thêm <i class="fas fa-arrow-right ml-1"></i></span>
            </div>
        </div>
        <div class="card p-8 text-center group hover:shadow-glow hover:-translate-y-2 transition-all duration-500 border border-transparent hover:border-emerald-100 reveal reveal-up" style="animation-delay: 0.3s">
            <div class="w-16 h-16 bg-gradient-to-br from-emerald-100 to-emerald-50 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 group-hover:rotate-6 group-hover:shadow-lg transition-all duration-500">
                <i class="fas fa-book text-emerald-600 text-2xl group-hover:text-emerald-700 transition-colors"></i>
            </div>
            <h3 class="text-xl font-bold font-headline mb-3 text-gray-800 group-hover:text-emerald-600 transition-colors duration-300">Đọc EPUB</h3>
            <p class="text-gray-500 leading-relaxed">Hỗ trợ định dạng EPUB với trải nghiệm đọc tối ưu, tùy chỉnh font chữ linh hoạt.</p>
            <div class="mt-5 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-500">
                <span class="text-emerald-600 text-sm font-semibold">Tìm hiểu thêm <i class="fas fa-arrow-right ml-1"></i></span>
            </div>
        </div>
        <div class="card p-8 text-center group hover:shadow-glow hover:-translate-y-2 transition-all duration-500 border border-transparent hover:border-violet-100 reveal reveal-right" style="animation-delay: 0.5s">
            <div class="w-16 h-16 bg-gradient-to-br from-violet-100 to-violet-50 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 group-hover:rotate-6 group-hover:shadow-lg transition-all duration-500">
                <i class="fas fa-bookmark text-violet-600 text-2xl group-hover:text-violet-700 transition-colors"></i>
            </div>
            <h3 class="text-xl font-bold font-headline mb-3 text-gray-800 group-hover:text-violet-600 transition-colors duration-300">Lưu tiến trình</h3>
            <p class="text-gray-500 leading-relaxed">Tự động lưu vị trí đọc, tiếp tục bất kỳ lúc nào bạn muốn trên mọi thiết bị.</p>
            <div class="mt-5 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-500">
                <span class="text-violet-600 text-sm font-semibold">Tìm hiểu thêm <i class="fas fa-arrow-right ml-1"></i></span>
            </div>
        </div>
    </div>
</section>

<!-- Popular Books (Sách yêu thích) -->
<% if (typeof popularBooks !== 'undefined' && popularBooks.length > 0) { %>
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4 reveal reveal-up">
            <div>
                <p class="text-sm font-bold text-red-500 uppercase tracking-[0.2em] mb-3">
                    <i class="fas fa-fire mr-1"></i> Đang hot
                </p>
                <h2 class="text-4xl font-extrabold font-headline text-gray-800">Sách được yêu thích</h2>
            </div>
            <a href="/books" class="text-primary-600 font-bold inline-flex items-center gap-2 hover:gap-3 transition-all duration-300">
                Khám phá thêm <i class="fas fa-arrow-right"></i>
            </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
            <% popularBooks.forEach(function(book, index) { %>
                <a href="/books/<%= book.id %>" class="group reveal reveal-up" style="animation-delay: <%= 0.1 * (index % 6) %>s">
                    <div class="card overflow-hidden">
                        <div class="aspect-[3/4] bg-gray-100 relative overflow-hidden">
                            <% if (book.cover_image) { %>
                                <div class="skeleton absolute inset-0"></div>
                                <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="book-cover-img w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" style="opacity:0;transition:opacity 0.4s ease" onload="this.style.opacity=1; this.previousElementSibling.style.display='none';">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-400 to-primary-600">
                                    <i class="fas fa-book text-white text-4xl"></i>
                                </div>
                            <% } %>
                            <div class="absolute top-2 left-2">
                                <span class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded shadow-md">
                                    <i class="fas fa-fire"></i> #<%= index + 1 %>
                                </span>
                            </div>
                            <div class="absolute top-2 right-2">
                                <span class="bg-white/90 backdrop-blur-sm text-xs font-bold px-2.5 py-1 rounded-lg uppercase
                                    <%= book.file_type === 'pdf' ? 'text-red-600' : 'text-emerald-600' %>">
                                    <%= book.file_type %>
                                </span>
                            </div>
                            <!-- Hover overlay -->
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-3">
                                <span class="text-white text-xs font-semibold"><i class="fas fa-eye mr-1"></i> <%= book.views || 0 %> lượt đọc</span>
                            </div>
                        </div>
                        <div class="p-3">
                            <h3 class="font-bold text-sm text-gray-800 truncate group-hover:text-primary-600 transition-colors" title="<%= book.title %>"><%= book.title %></h3>
                            <p class="text-xs text-gray-400 truncate mt-1"><%= book.author %></p>
                        </div>
                    </div>
                </a>
            <% }); %>
        </div>
    </div>
</section>
<% } %>

<!-- Recent Books -->
<% if (typeof recentBooks !== 'undefined' && recentBooks.length > 0) { %>
<section class="bg-surface-container-low py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4 reveal reveal-up">
            <div>
                <p class="text-sm font-bold text-primary-600 uppercase tracking-[0.2em] mb-3">Mới cập nhật</p>
                <h2 class="text-4xl font-extrabold font-headline text-gray-800">Sách nổi bật</h2>
            </div>
            <a href="/books" class="text-primary-600 font-bold inline-flex items-center gap-2 hover:gap-3 transition-all duration-300">
                Xem tất cả <i class="fas fa-arrow-right"></i>
            </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
            <% recentBooks.forEach(function(book) { %>
                                <a href="/books/<%= book.id %>" class="group reveal reveal-up" style="animation-delay: <%= 0.1 * (recentBooks.indexOf(book) % 6) %>s">
                    <div class="card overflow-hidden">
                        <div class="aspect-[3/4] bg-gray-100 relative overflow-hidden">
                                                        <% if (book.cover_image) { %>
                                <div class="skeleton absolute inset-0"></div>
                                <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="book-cover-img w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" style="opacity:0;transition:opacity 0.4s ease">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-400 to-primary-600">
                                    <i class="fas fa-book text-white text-4xl"></i>
                                </div>
                            <% } %>
                            <div class="absolute top-2 right-2">
                                <span class="bg-white/90 backdrop-blur-sm text-xs font-bold px-2.5 py-1 rounded-lg uppercase
                                    <%= book.file_type === 'pdf' ? 'text-red-600' : 'text-emerald-600' %>">
                                    <%= book.file_type %>
                                </span>
                            </div>
                            <!-- Hover overlay -->
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-3">
                                <span class="text-white text-xs font-semibold"><i class="fas fa-book-reader mr-1"></i> Đọc ngay</span>
                            </div>
                        </div>
                        <div class="p-3">
                            <h3 class="font-bold text-sm text-gray-800 truncate group-hover:text-primary-600 transition-colors" title="<%= book.title %>"><%= book.title %></h3>
                            <p class="text-xs text-gray-400 truncate mt-1"><%= book.author %></p>
                        </div>
                    </div>
                </a>
            <% }); %>
        </div>
    </div>
</section>
<% } %>

<!-- CTA Section -->
<section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center rounded-3xl p-12 sm:p-16 relative overflow-hidden reveal reveal-fade" style="background: linear-gradient(135deg, #1e1b4b 0%, #4f46e5 50%, #7c3aed 100%);">
        <div class="absolute -top-20 -right-20 w-64 h-64 bg-purple-500/20 rounded-full blur-3xl animate-pulse"></div>
        <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-indigo-400/15 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
        <div class="relative z-10">
                        <h2 class="text-3xl sm:text-4xl font-extrabold font-headline text-white mb-6 reveal reveal-up" style="animation-delay: 0.1s">Sẵn sàng khám phá?</h2>
            <p class="text-gray-400 text-lg mb-10 max-w-xl mx-auto leading-relaxed reveal reveal-up" style="animation-delay: 0.2s">Tham gia cộng đồng đọc sách trực tuyến. Hoàn toàn miễn phí, không giới hạn.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-up" style="animation-delay: 0.3s">
                                <a href="/auth/register" class="group px-8 py-4 bg-white text-primary-700 font-bold rounded-2xl shadow-glow hover:scale-105 hover:-translate-y-1 hover:shadow-soft-xl transition-all duration-300 text-lg">
                    <i class="fas fa-rocket mr-2 group-hover:rotate-12 transition-transform duration-300"></i> Bắt đầu đọc sách
                </a>
                <a href="/books" class="group px-8 py-4 border-2 border-white/30 text-white font-bold rounded-2xl hover:bg-white/10 hover:border-white/50 hover:scale-105 hover:-translate-y-1 transition-all duration-300 text-lg">
                    Khám phá thư viện
                </a>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>