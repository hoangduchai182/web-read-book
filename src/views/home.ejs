<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Hero Section -->
<section class="bg-gradient-to-br from-primary-600 to-primary-800 text-white">
    <div class="max-w-7xl mx-auto px-4 py-20 sm:py-28">
        <div class="text-center">
            <h1 class="text-4xl sm:text-5xl font-bold mb-6">Đọc sách mọi lúc, mọi nơi</h1>
            <p class="text-lg sm:text-xl text-primary-100 mb-8 max-w-2xl mx-auto">
                Khám phá kho tàng sách phong phú với hàng ngàn đầu sách thuộc nhiều thể loại.
                Hỗ trợ đọc PDF và EPUB trực tuyến.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <% if (typeof user !== 'undefined' && user) { %>
                    <a href="/books" class="bg-white text-primary-700 font-semibold py-3 px-8 rounded-lg hover:bg-primary-50 transition-colors text-lg">
                        <i class="fas fa-book-reader mr-2"></i> Vào thư viện
                    </a>
                <% } else { %>
                    <a href="/auth/register" class="bg-white text-primary-700 font-semibold py-3 px-8 rounded-lg hover:bg-primary-50 transition-colors text-lg">
                        <i class="fas fa-user-plus mr-2"></i> Đăng ký miễn phí
                    </a>
                    <a href="/auth/login" class="border-2 border-white text-white font-semibold py-3 px-8 rounded-lg hover:bg-white hover:text-primary-700 transition-colors text-lg">
                        <i class="fas fa-sign-in-alt mr-2"></i> Đăng nhập
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="max-w-7xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">Tính năng nổi bật</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card p-8 text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-file-pdf text-primary-600 text-2xl"></i>
            </div>
            <h3 class="text-xl font-semibold mb-3">Đọc PDF trực tuyến</h3>
            <p class="text-gray-600">Trình đọc PDF tích hợp, hỗ trợ zoom, tìm kiếm và đánh dấu trang.</p>
        </div>
        <div class="card p-8 text-center">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-book text-green-600 text-2xl"></i>
            </div>
            <h3 class="text-xl font-semibold mb-3">Đọc EPUB</h3>
            <p class="text-gray-600">Hỗ trợ định dạng EPUB với trải nghiệm đọc tối ưu, tùy chỉnh font chữ.</p>
        </div>
        <div class="card p-8 text-center">
            <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-bookmark text-purple-600 text-2xl"></i>
            </div>
            <h3 class="text-xl font-semibold mb-3">Lưu tiến trình</h3>
            <p class="text-gray-600">Tự động lưu vị trí đọc, tiếp tục đọc bất kỳ lúc nào bạn muốn.</p>
        </div>
    </div>
</section>

<!-- Recent Books -->
<% if (typeof recentBooks !== 'undefined' && recentBooks.length > 0) { %>
<section class="bg-gray-100 py-16">
    <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">Sách mới cập nhật</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
            <% recentBooks.forEach(function(book) { %>
                <a href="/books/<%= book.id %>" class="card group">
                    <div class="aspect-[3/4] bg-gray-200 relative overflow-hidden">
                        <% if (book.cover_image) { %>
                            <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                        <% } else { %>
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-400 to-primary-600">
                                <i class="fas fa-book text-white text-4xl"></i>
                            </div>
                        <% } %>
                        <div class="absolute top-2 right-2">
                            <span class="bg-white/90 text-xs font-semibold px-2 py-1 rounded uppercase
                                <%= book.file_type === 'pdf' ? 'text-red-600' : 'text-green-600' %>">
                                <%= book.file_type %>
                            </span>
                        </div>
                    </div>
                    <div class="p-3">
                        <h3 class="font-semibold text-sm text-gray-800 truncate"><%= book.title %></h3>
                        <p class="text-xs text-gray-500 truncate mt-1"><%= book.author %></p>
                    </div>
                </a>
            <% }); %>
        </div>
    </div>
</section>
<% } %>

<%- include('partials/footer') %>