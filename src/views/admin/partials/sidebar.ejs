<aside class="w-64 bg-gray-900 min-h-screen fixed left-0 top-0 z-40">
    <div class="p-6 border-b border-gray-700">
        <a href="/" class="flex items-center gap-2">
            <i class="fas fa-book-open text-primary-400 text-2xl"></i>
            <span class="text-xl font-bold text-white">BookRead</span>
        </a>
        <p class="text-gray-400 text-xs mt-1">Trang quản trị</p>
    </div>

    <nav class="p-4 space-y-2">
        <a href="/admin" class="sidebar-link <%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>">
            <i class="fas fa-tachometer-alt w-5"></i>
            <span>Dashboard</span>
        </a>
        <a href="/admin/books" class="sidebar-link <%= typeof active !== 'undefined' && active === 'books' ? 'active' : '' %>">
            <i class="fas fa-book w-5"></i>
            <span>Quản lý sách</span>
        </a>
        <a href="/admin/users" class="sidebar-link <%= typeof active !== 'undefined' && active === 'users' ? 'active' : '' %>">
            <i class="fas fa-users w-5"></i>
            <span>Quản lý người dùng</span>
        </a>

        <div class="border-t border-gray-700 my-4"></div>

        <a href="/" class="sidebar-link">
            <i class="fas fa-home w-5"></i>
            <span>Về trang chủ</span>
        </a>
        <a href="/auth/logout" class="sidebar-link text-red-400 hover:text-red-300">
            <i class="fas fa-sign-out-alt w-5"></i>
            <span>Đăng xuất</span>
        </a>
    </nav>

    <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-700">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-primary-600 rounded-full flex items-center justify-center">
                <i class="fas fa-user text-white text-sm"></i>
            </div>
            <div>
                <p class="text-white text-sm font-medium"><%= user.full_name %></p>
                <p class="text-gray-400 text-xs"><%= user.role %></p>
            </div>
        </div>
    </div>
</aside>