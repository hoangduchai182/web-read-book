<%- include('../../partials/header') %>

<% const active = 'users'; %>
<div class="flex">
    <%- include('../partials/sidebar') %>

    <main class="ml-64 flex-1 p-8 min-h-screen">
        <div class="mb-8">
            <a href="/admin/users" class="text-primary-600 hover:text-primary-700 mb-2 inline-block">
                <i class="fas fa-arrow-left mr-1"></i> Quay lại danh sách
            </a>
            <h1 class="text-3xl font-bold text-gray-800">Chỉnh sửa người dùng</h1>
            <p class="text-gray-500 mt-1">Cập nhật thông tin người dùng #<%= editUser.id %> - <%= editUser.username %></p>
        </div>

        <%- include('../../partials/flash') %>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-4xl">
            <!-- Form cập nhật thông tin -->
            <div class="card p-8">
                <h2 class="text-xl font-bold text-gray-800 mb-6">
                    <i class="fas fa-user-edit text-primary-600 mr-2"></i>Thông tin tài khoản
                </h2>
                <form action="/admin/users/edit/<%= editUser.id %>" method="POST" class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">
                            Họ và tên <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fas fa-id-card"></i>
                            </span>
                            <input type="text" name="full_name" class="input-field pl-10" value="<%= editUser.full_name %>" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">
                            Tên đăng nhập <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fas fa-user"></i>
                            </span>
                            <input type="text" name="username" class="input-field pl-10" value="<%= editUser.username %>" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">
                            Email <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fas fa-envelope"></i>
                            </span>
                            <input type="email" name="email" class="input-field pl-10" value="<%= editUser.email %>" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">
                            Vai trò <span class="text-red-500">*</span>
                        </label>
                        <select name="role" class="input-field">
                            <option value="user" <%= editUser.role === 'user' ? 'selected' : '' %>>User - Người dùng thường</option>
                            <option value="admin" <%= editUser.role === 'admin' ? 'selected' : '' %>>Admin - Quản trị viên</option>
                        </select>
                    </div>

                    <div class="flex gap-4 pt-4">
                        <button type="submit" class="btn-primary py-3 px-8">
                            <i class="fas fa-save mr-2"></i> Lưu thông tin
                        </button>
                        <a href="/admin/users" class="btn-secondary py-3 px-8">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>

            <!-- Form đổi mật khẩu -->
            <div class="card p-8">
                <h2 class="text-xl font-bold text-gray-800 mb-6">
                    <i class="fas fa-key text-yellow-500 mr-2"></i>Đổi mật khẩu
                </h2>
                <form action="/admin/users/change-password/<%= editUser.id %>" method="POST" class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">
                            Mật khẩu mới <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input type="password" name="new_password" class="input-field pl-10" placeholder="Tối thiểu 6 ký tự" minlength="6" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">
                            Xác nhận mật khẩu mới <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input type="password" name="confirm_password" class="input-field pl-10" placeholder="Nhập lại mật khẩu mới" minlength="6" required>
                        </div>
                    </div>

                    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                        <p class="text-yellow-700 text-sm">
                            <i class="fas fa-exclamation-triangle mr-1"></i>
                            Sau khi đổi mật khẩu, người dùng sẽ cần đăng nhập lại với mật khẩu mới.
                        </p>
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="btn-primary py-3 px-8 bg-yellow-500 hover:bg-yellow-600 border-yellow-500 hover:border-yellow-600">
                            <i class="fas fa-key mr-2"></i> Đổi mật khẩu
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Thông tin thêm -->
        <div class="card p-6 max-w-4xl mt-8">
            <h3 class="font-bold text-gray-700 mb-3"><i class="fas fa-info-circle text-blue-500 mr-2"></i>Thông tin thêm</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                <div>
                    <p class="text-gray-400">ID</p>
                    <p class="font-medium text-gray-700">#<%= editUser.id %></p>
                </div>
                <div>
                    <p class="text-gray-400">Vai trò hiện tại</p>
                    <p class="font-medium">
                        <span class="text-xs px-2 py-1 rounded-full
                            <%= editUser.role === 'admin' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700' %>">
                            <%= editUser.role === 'admin' ? 'Admin' : 'User' %>
                        </span>
                    </p>
                </div>
                <div>
                    <p class="text-gray-400">Ngày tạo</p>
                    <p class="font-medium text-gray-700"><%= new Date(editUser.created_at).toLocaleDateString('vi-VN') %></p>
                </div>
                <div>
                    <p class="text-gray-400">Cập nhật lần cuối</p>
                    <p class="font-medium text-gray-700"><%= editUser.updated_at ? new Date(editUser.updated_at).toLocaleDateString('vi-VN') : 'Chưa cập nhật' %></p>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('../../partials/footer') %>