<%- include('../../partials/header') %>

<% const active = 'users'; %>
<div class="flex">
    <%- include('../partials/sidebar') %>

    <main class="ml-64 flex-1 p-8 min-h-screen bg-surface">
        <div class="mb-10">
            <a href="/admin/users" class="inline-flex items-center gap-2 text-sm font-semibold text-primary-600 hover:text-primary-700 hover:gap-3 transition-all duration-300 mb-4">
                <i class="fas fa-arrow-left"></i> Quay lại danh sách
            </a>
            <h1 class="text-3xl font-extrabold font-headline text-gray-800">Chỉnh sửa người dùng</h1>
            <p class="text-gray-400 mt-1 text-sm">Cập nhật thông tin người dùng #<%= editUser.id %> — <strong><%= editUser.username %></strong></p>
        </div>

        <%- include('../../partials/flash') %>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl">
            <!-- Form cập nhật thông tin -->
            <div class="bg-white rounded-2xl shadow-soft border border-gray-100/50 p-8">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-10 h-10 rounded-xl bg-primary-50 flex items-center justify-center">
                        <i class="fas fa-user-edit text-primary-600"></i>
                    </div>
                    <h2 class="text-xl font-bold font-headline text-gray-800">Thông tin tài khoản</h2>
                </div>
                <form action="/admin/users/edit/<%= editUser.id %>" method="POST" class="space-y-5">
                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-2">
                            Họ và tên <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400">
                                <i class="fas fa-id-card text-sm"></i>
                            </span>
                            <input type="text" name="full_name" class="input-field pl-11" value="<%= editUser.full_name %>" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-2">
                            Tên đăng nhập <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400">
                                <i class="fas fa-user text-sm"></i>
                            </span>
                            <input type="text" name="username" class="input-field pl-11" value="<%= editUser.username %>" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-2">
                            Email <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400">
                                <i class="fas fa-envelope text-sm"></i>
                            </span>
                            <input type="email" name="email" class="input-field pl-11" value="<%= editUser.email %>" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-2">
                            Vai trò <span class="text-red-500">*</span>
                        </label>
                        <select name="role" class="input-field">
                            <option value="user" <%= editUser.role === 'user' ? 'selected' : '' %>>User - Người dùng thường</option>
                            <option value="admin" <%= editUser.role === 'admin' ? 'selected' : '' %>>Admin - Quản trị viên</option>
                        </select>
                    </div>

                    <div class="flex gap-4 pt-4">
                        <button type="submit" class="btn-primary py-3.5 px-8">
                            <i class="fas fa-save mr-2"></i> Lưu thông tin
                        </button>
                        <a href="/admin/users" class="btn-secondary py-3.5 px-8">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>

            <!-- Form đổi mật khẩu -->
            <div class="bg-white rounded-2xl shadow-soft border border-gray-100/50 p-8">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center">
                        <i class="fas fa-key text-amber-500"></i>
                    </div>
                    <h2 class="text-xl font-bold font-headline text-gray-800">Đổi mật khẩu</h2>
                </div>
                <form action="/admin/users/change-password/<%= editUser.id %>" method="POST" class="space-y-5">
                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-2">
                            Mật khẩu mới <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400">
                                <i class="fas fa-lock text-sm"></i>
                            </span>
                            <input type="password" name="new_password" class="input-field pl-11" placeholder="Tối thiểu 6 ký tự" minlength="6" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-2">
                            Xác nhận mật khẩu mới <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400">
                                <i class="fas fa-lock text-sm"></i>
                            </span>
                            <input type="password" name="confirm_password" class="input-field pl-11" placeholder="Nhập lại mật khẩu mới" minlength="6" required>
                        </div>
                    </div>

                    <div class="flex items-start gap-3 p-4 bg-amber-50 border border-amber-100 rounded-2xl">
                        <i class="fas fa-exclamation-triangle text-amber-500 text-sm mt-0.5"></i>
                        <p class="text-amber-700 text-xs leading-relaxed">
                            Sau khi đổi mật khẩu, người dùng sẽ cần đăng nhập lại với mật khẩu mới.
                        </p>
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="inline-flex items-center px-8 py-3.5 bg-gradient-to-r from-amber-500 to-amber-400 hover:from-amber-600 hover:to-amber-500 text-white font-semibold rounded-xl shadow-soft transition-all duration-300 active:scale-[0.97]">
                            <i class="fas fa-key mr-2"></i> Đổi mật khẩu
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Thông tin thêm -->
        <div class="bg-white rounded-2xl shadow-soft border border-gray-100/50 p-6 max-w-5xl mt-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-xl bg-primary-50 flex items-center justify-center">
                    <i class="fas fa-info text-primary-600 text-sm"></i>
                </div>
                <h3 class="font-bold font-headline text-gray-800">Thông tin thêm</h3>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                <div class="p-4 bg-surface-container-low rounded-2xl">
                    <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">ID</p>
                    <p class="font-bold text-gray-700">#<%= editUser.id %></p>
                </div>
                <div class="p-4 bg-surface-container-low rounded-2xl">
                    <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Vai trò</p>
                    <span class="text-xs font-bold px-2.5 py-1 rounded-lg
                        <%= editUser.role === 'admin' ? 'bg-red-50 text-red-600' : 'bg-primary-50 text-primary-600' %>">
                        <%= editUser.role === 'admin' ? '👑 Admin' : 'User' %>
                    </span>
                </div>
                <div class="p-4 bg-surface-container-low rounded-2xl">
                    <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Ngày tạo</p>
                    <p class="font-bold text-gray-700 text-sm"><%= new Date(editUser.created_at).toLocaleDateString('vi-VN') %></p>
                </div>
                <div class="p-4 bg-surface-container-low rounded-2xl">
                    <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Cập nhật</p>
                    <p class="font-bold text-gray-700 text-sm"><%= editUser.updated_at ? new Date(editUser.updated_at).toLocaleDateString('vi-VN') : 'Chưa cập nhật' %></p>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>