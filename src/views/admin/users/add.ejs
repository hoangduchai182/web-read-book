<%- include('../../partials/header') %> <% const active = 'users'; %>
<div class="flex">
  <%- include('../partials/sidebar') %>
  <main class="md:ml-64 flex-1 p-4 md:p-8 min-h-screen bg-surface">
    <div class="mb-10">
      <a
        href="/admin/users"
        class="inline-flex items-center gap-2 text-sm font-semibold text-primary-600 hover:text-primary-700 hover:gap-3 transition-all duration-300 mb-4"
      >
        <i class="fas fa-arrow-left"></i> Quay lại danh sách
      </a>
      <h1 class="text-3xl font-extrabold font-headline text-gray-800">
        Thêm người dùng mới
      </h1>
    </div>

    <%- include('../../partials/flash') %>

    <div
      class="bg-white rounded-2xl shadow-soft border border-gray-100/50 p-8 sm:p-10 max-w-2xl"
    >
      <form action="/admin/users/add" method="POST" class="space-y-6">
        <div>
          <label class="block text-sm font-semibold text-gray-600 mb-2">
            Họ và tên <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <span
              class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400"
            >
              <i class="fas fa-id-card text-sm"></i>
            </span>
            <input
              type="text"
              name="full_name"
              class="input-field pl-11"
              placeholder="Nhập họ và tên"
              required
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-600 mb-2">
            Tên đăng nhập <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <span
              class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400"
            >
              <i class="fas fa-user text-sm"></i>
            </span>
            <input
              type="text"
              name="username"
              class="input-field pl-11"
              placeholder="Nhập tên đăng nhập"
              required
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-600 mb-2">
            Email <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <span
              class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400"
            >
              <i class="fas fa-envelope text-sm"></i>
            </span>
            <input
              type="email"
              name="email"
              class="input-field pl-11"
              placeholder="Nhập email"
              required
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-600 mb-2">
            Mật khẩu <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <span
              class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400"
            >
              <i class="fas fa-lock text-sm"></i>
            </span>
            <input
              type="password"
              name="password"
              class="input-field pl-11"
              placeholder="Tối thiểu 6 ký tự"
              minlength="6"
              required
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-600 mb-2">
            Vai trò <span class="text-red-500">*</span>
          </label>
          <select name="role" class="input-field">
            <option value="user">User - Người dùng thường</option>
            <option value="admin">Admin - Quản trị viên</option>
          </select>
          <div class="flex items-start gap-2 mt-3 p-3 bg-primary-50 rounded-xl">
            <i class="fas fa-info-circle text-primary-500 text-sm mt-0.5"></i>
            <p class="text-primary-600 text-xs leading-relaxed">
              Admin có quyền truy cập trang quản trị và quản lý toàn bộ hệ thống
            </p>
          </div>
        </div>

        <div class="flex gap-4 pt-6">
          <button type="submit" class="btn-primary py-3.5 px-8">
            <i class="fas fa-user-plus mr-2"></i> Thêm người dùng
          </button>
          <a href="/admin/users" class="btn-secondary py-3.5 px-8"> Hủy bỏ </a>
        </div>
      </form>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
