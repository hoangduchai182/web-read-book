<%- include('../partials/header') %>

<div class="flex">
    <%- include('partials/sidebar') %>

    <main class="md:ml-64 flex-1 p-4 md:p-8 min-h-screen bg-surface">
        <!-- Page Header -->
        <div class="mb-10">
            <p class="text-sm font-bold text-primary-600 uppercase tracking-[0.2em] mb-2">Tổng quan</p>
            <h1 class="text-3xl font-extrabold font-headline text-gray-800">Dashboard</h1>
        </div>

        <%- include('../partials/flash') %>

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
            <div class="bg-white rounded-2xl shadow-soft p-6 border border-gray-100/50 hover:shadow-soft-lg transition-all duration-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Tổng sách</p>
                        <p class="text-4xl font-extrabold font-headline text-gray-800 mt-2"><%= bookCount %></p>
                    </div>
                    <div class="w-14 h-14 bg-gradient-to-br from-primary-100 to-primary-50 rounded-2xl flex items-center justify-center">
                        <i class="fas fa-book text-primary-600 text-lg"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-2xl shadow-soft p-6 border border-gray-100/50 hover:shadow-soft-lg transition-all duration-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Người dùng</p>
                        <p class="text-4xl font-extrabold font-headline text-gray-800 mt-2"><%= userCount %></p>
                    </div>
                    <div class="w-14 h-14 bg-gradient-to-br from-emerald-100 to-emerald-50 rounded-2xl flex items-center justify-center">
                        <i class="fas fa-users text-emerald-600 text-lg"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-2xl shadow-soft p-6 border border-gray-100/50 hover:shadow-soft-lg transition-all duration-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Thể loại</p>
                        <p class="text-4xl font-extrabold font-headline text-gray-800 mt-2"><%= categoryCount %></p>
                    </div>
                    <div class="w-14 h-14 bg-gradient-to-br from-violet-100 to-violet-50 rounded-2xl flex items-center justify-center">
                        <i class="fas fa-folder text-violet-600 text-lg"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Data -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Sách mới thêm -->
            <div class="bg-white rounded-2xl shadow-soft border border-gray-100/50 overflow-hidden">
                <div class="p-5 border-b border-gray-100 flex items-center justify-between">
                    <h2 class="font-bold font-headline text-gray-800 flex items-center gap-2">
                        <div class="w-8 h-8 rounded-xl bg-primary-50 flex items-center justify-center">
                            <i class="fas fa-book text-primary-600 text-sm"></i>
                        </div>
                        Sách mới thêm
                    </h2>
                    <a href="/admin/books" class="text-primary-600 hover:text-primary-700 text-sm font-semibold inline-flex items-center gap-1 hover:gap-2 transition-all duration-300">
                        Xem tất cả <i class="fas fa-arrow-right text-xs"></i>
                    </a>
                </div>
                <div class="divide-y divide-gray-50">
                    <% if (recentBooks.length > 0) { %>
                        <% recentBooks.forEach(function(book) { %>
                            <div class="p-4 flex items-center gap-4 hover:bg-surface-container-low transition-colors duration-300">
                                <div class="w-10 h-10 rounded-xl flex items-center justify-center
                                    <%= book.file_type === 'pdf' ? 'bg-red-50' : 'bg-emerald-50' %>">
                                    <i class="fas <%= book.file_type === 'pdf' ? 'fa-file-pdf text-red-500' : 'fa-book text-emerald-500' %> text-sm"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="font-semibold text-sm text-gray-800 truncate"><%= book.title %></p>
                                    <p class="text-xs text-gray-400"><%= book.author %></p>
                                </div>
                                <span class="text-xs text-gray-400 font-medium"><%= new Date(book.created_at).toLocaleDateString('vi-VN') %></span>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="p-10 text-center">
                            <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-3">
                                <i class="fas fa-inbox text-gray-300 text-xl"></i>
                            </div>
                            <p class="text-sm text-gray-400">Chưa có sách nào</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Người dùng mới -->
            <div class="bg-white rounded-2xl shadow-soft border border-gray-100/50 overflow-hidden">
                <div class="p-5 border-b border-gray-100 flex items-center justify-between">
                    <h2 class="font-bold font-headline text-gray-800 flex items-center gap-2">
                        <div class="w-8 h-8 rounded-xl bg-emerald-50 flex items-center justify-center">
                            <i class="fas fa-users text-emerald-600 text-sm"></i>
                        </div>
                        Người dùng mới
                    </h2>
                    <a href="/admin/users" class="text-primary-600 hover:text-primary-700 text-sm font-semibold inline-flex items-center gap-1 hover:gap-2 transition-all duration-300">
                        Xem tất cả <i class="fas fa-arrow-right text-xs"></i>
                    </a>
                </div>
                <div class="divide-y divide-gray-50">
                    <% if (recentUsers.length > 0) { %>
                        <% recentUsers.forEach(function(u) { %>
                            <div class="p-4 flex items-center gap-4 hover:bg-surface-container-low transition-colors duration-300">
                                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-500 to-primary-400 flex items-center justify-center">
                                    <span class="text-white text-xs font-bold"><%= u.full_name.charAt(0).toUpperCase() %></span>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="font-semibold text-sm text-gray-800 truncate"><%= u.full_name %></p>
                                    <p class="text-xs text-gray-400"><%= u.email %></p>
                                </div>
                                <span class="text-xs font-bold px-2.5 py-1 rounded-lg
                                    <%= u.role === 'admin' ? 'bg-red-50 text-red-600' : 'bg-primary-50 text-primary-600' %>">
                                    <%= u.role === 'admin' ? '👑 Admin' : 'User' %>
                                </span>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="p-10 text-center">
                            <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-3">
                                <i class="fas fa-inbox text-gray-300 text-xl"></i>
                            </div>
                            <p class="text-sm text-gray-400">Chưa có người dùng nào</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('partials/footer') %>