<%- include('../partials/header') %>

<div class="flex">
    <%- include('partials/sidebar') %>

    <main class="ml-64 flex-1 p-8 min-h-screen">
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Dashboard</h1>
            <p class="text-gray-500 mt-1">Tổng quan hệ thống</p>
        </div>

        <%- include('../partials/flash') %>

        <!-- Thống kê -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
            <div class="card p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm">Tổng sách</p>
                        <p class="text-3xl font-bold text-gray-800 mt-1"><%= bookCount %></p>
                    </div>
                    <div class="w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-book text-primary-600 text-xl"></i>
                    </div>
                </div>
            </div>
            <div class="card p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm">Người dùng</p>
                        <p class="text-3xl font-bold text-gray-800 mt-1"><%= userCount %></p>
                    </div>
                    <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-users text-green-600 text-xl"></i>
                    </div>
                </div>
            </div>
            <div class="card p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm">Thể loại</p>
                        <p class="text-3xl font-bold text-gray-800 mt-1"><%= categoryCount %></p>
                    </div>
                    <div class="w-14 h-14 bg-purple-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-folder text-purple-600 text-xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sách & Người dùng mới -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Sách mới thêm -->
            <div class="card">
                <div class="p-4 border-b flex items-center justify-between">
                    <h2 class="font-bold text-gray-800"><i class="fas fa-book mr-2 text-primary-600"></i>Sách mới thêm</h2>
                    <a href="/admin/books" class="text-primary-600 hover:text-primary-700 text-sm">Xem tất cả →</a>
                </div>
                <div class="divide-y">
                    <% if (recentBooks.length > 0) { %>
                        <% recentBooks.forEach(function(book) { %>
                            <div class="p-4 flex items-center gap-4 hover:bg-gray-50">
                                <div class="w-10 h-10 rounded-lg flex items-center justify-center
                                    <%= book.file_type === 'pdf' ? 'bg-red-100' : 'bg-green-100' %>">
                                    <i class="fas <%= book.file_type === 'pdf' ? 'fa-file-pdf text-red-600' : 'fa-book text-green-600' %>"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="font-medium text-sm text-gray-800 truncate"><%= book.title %></p>
                                    <p class="text-xs text-gray-500"><%= book.author %></p>
                                </div>
                                <span class="text-xs text-gray-400"><%= new Date(book.created_at).toLocaleDateString('vi-VN') %></span>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="p-8 text-center text-gray-400">
                            <i class="fas fa-inbox text-3xl mb-2"></i>
                            <p>Chưa có sách nào</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Người dùng mới -->
            <div class="card">
                <div class="p-4 border-b flex items-center justify-between">
                    <h2 class="font-bold text-gray-800"><i class="fas fa-users mr-2 text-green-600"></i>Người dùng mới</h2>
                    <a href="/admin/users" class="text-primary-600 hover:text-primary-700 text-sm">Xem tất cả →</a>
                </div>
                <div class="divide-y">
                    <% if (recentUsers.length > 0) { %>
                        <% recentUsers.forEach(function(u) { %>
                            <div class="p-4 flex items-center gap-4 hover:bg-gray-50">
                                <div class="w-10 h-10 bg-gray-200 rounded-full flex items-center justify-center">
                                    <i class="fas fa-user text-gray-500"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="font-medium text-sm text-gray-800 truncate"><%= u.full_name %></p>
                                    <p class="text-xs text-gray-500"><%= u.email %></p>
                                </div>
                                <span class="text-xs px-2 py-1 rounded-full
                                    <%= u.role === 'admin' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700' %>">
                                    <%= u.role %>
                                </span>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="p-8 text-center text-gray-400">
                            <i class="fas fa-inbox text-3xl mb-2"></i>
                            <p>Chưa có người dùng nào</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>