<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="min-h-[85vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
        <!-- Card -->
        <div class="bg-white rounded-3xl shadow-soft-xl p-8 sm:p-10 border border-gray-100/50">
            <!-- Header -->
            <div class="text-center mb-10">
                <div class="w-16 h-16 bg-gradient-to-br from-primary-100 to-primary-50 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-soft">
                    <i class="fas fa-sign-in-alt text-primary-600 text-xl"></i>
                </div>
                <h1 class="text-3xl font-extrabold font-headline text-gray-800">Đăng nhập</h1>
                <p class="text-gray-400 mt-2 text-sm">Chào mừng bạn quay trở lại BookRead</p>
            </div>

            <%- include('../partials/flash') %>

            <form action="/auth/login" method="POST" class="space-y-5">
                <div>
                    <label class="block text-sm font-semibold text-gray-600 mb-2">Tên đăng nhập</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400">
                            <i class="fas fa-user text-sm"></i>
                        </span>
                        <input type="text" name="username" class="input-field pl-11" placeholder="Nhập tên đăng nhập" required>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-600 mb-2">Mật khẩu</label>
                    <div class="relative">
                        <span
                            class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400"
                        >
                            <i class="fas fa-lock text-sm"></i>
                        </span>
                        <input
                            type="password"
                            name="password"
                            class="input-field pl-11"
                            placeholder="Nhập mật khẩu"
                            required
                        />
                    </div>
                </div>

                <button type="submit" class="btn-primary w-full py-3.5 text-base mt-2">
                    <i class="fas fa-sign-in-alt mr-2"></i> Đăng nhập
                </button>
            </form>

            <div class="mt-8 text-center">
                <p class="text-gray-500 text-sm">
                    Chưa có tài khoản?
                    <a
                        href="/auth/register"
                        class="text-primary-600 hover:text-primary-700 font-bold transition-colors"
                    >Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>