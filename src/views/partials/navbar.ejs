<% const currentPath = typeof reqPath !== 'undefined' ? reqPath : '/'; %>
<nav class="fixed top-0 w-full z-50 bg-white/80 dark:bg-gray-900/80 backdrop-blur-xl shadow-[0_4px_32px_rgba(25,28,30,0.06)] border-b border-gray-100/50 dark:border-gray-800/50 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-2.5 group">
                <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-primary-600 to-primary-400 flex items-center justify-center shadow-glow group-hover:scale-110 transition-transform duration-300">
                    <i class="fas fa-book-open text-white text-sm"></i>
                </div>
                <span class="text-xl font-extrabold tracking-tight font-headline text-primary-700 dark:text-primary-400">BookRead</span>
            </a>

            <!-- Navigation Links -->
            <div class="hidden md:flex items-center gap-1">
                <a href="/" class="nav-link px-4 py-2 text-sm font-medium rounded-xl transition-all duration-300 <%= currentPath === '/' ? 'text-primary-600 bg-primary-50 dark:text-primary-400 dark:bg-primary-900/30' : 'text-gray-600 dark:text-gray-300 hover:text-primary-600 hover:bg-primary-50 dark:hover:text-primary-400 dark:hover:bg-primary-900/20' %>">
                    <i class="fas fa-home mr-1.5"></i> Trang chủ
                </a>
                <% if (typeof user !== 'undefined' && user) { %>
                    <a href="/books" class="nav-link px-4 py-2 text-sm font-medium rounded-xl transition-all duration-300 <%= currentPath.startsWith('/books') ? 'text-primary-600 bg-primary-50 dark:text-primary-400 dark:bg-primary-900/30' : 'text-gray-600 dark:text-gray-300 hover:text-primary-600 hover:bg-primary-50 dark:hover:text-primary-400 dark:hover:bg-primary-900/20' %>">
                        <i class="fas fa-book mr-1.5"></i> Thư viện
                    </a>
                    <% if (user.role === 'admin') { %>
                        <a href="/admin" class="nav-link px-4 py-2 text-sm font-medium rounded-xl transition-all duration-300 <%= currentPath.startsWith('/admin') ? 'text-primary-600 bg-primary-50 dark:text-primary-400 dark:bg-primary-900/30' : 'text-gray-600 dark:text-gray-300 hover:text-primary-600 hover:bg-primary-50 dark:hover:text-primary-400 dark:hover:bg-primary-900/20' %>">
                            <i class="fas fa-cog mr-1.5"></i> Quản trị
                        </a>
                    <% } %>
                <% } %>

                                <!-- Dark Mode Toggle -->
                <button id="dark-mode-toggle" class="w-9 h-9 flex items-center justify-center rounded-xl text-gray-500 dark:text-yellow-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-all duration-300 ml-1" title="Chuyển chế độ sáng/tối">
                    <i id="theme-icon" class="fas fa-moon text-sm"></i>
                </button>

                <% if (typeof user !== 'undefined' && user) { %>
                    <div class="ml-3 pl-3 border-l border-gray-200 dark:border-gray-700 flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center">
                            <span class="text-white text-xs font-bold"><%= user.full_name.charAt(0).toUpperCase() %></span>
                        </div>
                        <span class="text-sm font-semibold text-gray-700 dark:text-gray-200"><%= user.full_name %></span>
                        <a href="/auth/logout" class="ml-1 px-3 py-1.5 text-xs font-semibold text-red-600 bg-red-50 hover:bg-red-100 dark:bg-red-900/30 dark:hover:bg-red-900/50 rounded-lg transition-all duration-300">
                            <i class="fas fa-sign-out-alt mr-1"></i> Đăng xuất
                        </a>
                    </div>
                <% } else { %>
                    <div class="ml-3 pl-3 border-l border-gray-200 dark:border-gray-700 flex items-center gap-3">
                        <a href="/auth/login" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 rounded-xl transition-all duration-300">
                            Đăng nhập
                        </a>
                        <a href="/auth/register" class="px-5 py-2 text-sm font-semibold text-white bg-gradient-to-r from-primary-600 to-primary-500 rounded-xl shadow-soft hover:shadow-glow hover:opacity-90 active:scale-95 transition-all duration-300">
                            Đăng ký
                        </a>
                    </div>
                <% } %>
            </div>

            <!-- Mobile: Dark mode + Menu button -->
            <div class="md:hidden flex items-center gap-1">
                                <button id="dark-mode-toggle-mobile" class="w-10 h-10 flex items-center justify-center text-gray-600 dark:text-yellow-400 hover:text-primary-600 hover:bg-primary-50 dark:hover:bg-gray-800 rounded-xl transition-all duration-300" title="Chuyển chế độ sáng/tối">
                    <i id="theme-icon-m" class="fas fa-moon text-lg"></i>
                </button>
                <button id="mobile-menu-btn" class="w-10 h-10 flex items-center justify-center text-gray-600 dark:text-gray-400 hover:text-primary-600 hover:bg-primary-50 dark:hover:bg-gray-800 rounded-xl transition-all duration-300">
                    <i class="fas fa-bars text-lg"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white/95 dark:bg-gray-900/95 backdrop-blur-xl border-t border-gray-100 dark:border-gray-800">
        <div class="px-4 py-4 space-y-1">
            <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= currentPath === '/' ? 'text-primary-600 bg-primary-50 dark:text-primary-400 dark:bg-primary-900/30' : 'text-gray-600 dark:text-gray-300 hover:text-primary-600 hover:bg-primary-50 dark:hover:bg-gray-800' %>">
                <i class="fas fa-home w-5"></i> Trang chủ
            </a>
            <% if (typeof user !== 'undefined' && user) { %>
                <a href="/books" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= currentPath.startsWith('/books') ? 'text-primary-600 bg-primary-50 dark:text-primary-400 dark:bg-primary-900/30' : 'text-gray-600 dark:text-gray-300 hover:text-primary-600 hover:bg-primary-50 dark:hover:bg-gray-800' %>">
                    <i class="fas fa-book w-5"></i> Thư viện
                </a>
                <% if (user.role === 'admin') { %>
                    <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= currentPath.startsWith('/admin') ? 'text-primary-600 bg-primary-50 dark:text-primary-400 dark:bg-primary-900/30' : 'text-gray-600 dark:text-gray-300 hover:text-primary-600 hover:bg-primary-50 dark:hover:bg-gray-800' %>">
                        <i class="fas fa-cog w-5"></i> Quản trị
                    </a>
                <% } %>
                <div class="border-t border-gray-100 dark:border-gray-800 my-2"></div>
                <div class="px-4 py-3 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center">
                            <span class="text-white text-xs font-bold"><%= user.full_name.charAt(0).toUpperCase() %></span>
                        </div>
                        <span class="text-sm font-semibold text-gray-700 dark:text-gray-200"><%= user.full_name %></span>
                    </div>
                    <a href="/auth/logout" class="px-3 py-1.5 text-xs font-semibold text-red-600 bg-red-50 dark:bg-red-900/30 rounded-lg">
                        <i class="fas fa-sign-out-alt mr-1"></i> Đăng xuất
                    </a>
                </div>
            <% } else { %>
                <div class="border-t border-gray-100 dark:border-gray-800 my-2"></div>
                <div class="px-4 py-3 flex gap-3">
                    <a href="/auth/login" class="flex-1 text-center px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-xl transition-all">
                        Đăng nhập
                    </a>
                    <a href="/auth/register" class="flex-1 text-center px-4 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-primary-600 to-primary-500 rounded-xl">
                        Đăng ký
                    </a>
                </div>
            <% } %>
        </div>
    </div>
</nav>
<!-- Spacer for fixed navbar -->
<div class="h-16"></div>

<script>
    // Mobile menu toggle
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });

        // Dark mode
    (function() {
        function updateIcons(isDark) {
            var icons = [document.getElementById('theme-icon'), document.getElementById('theme-icon-m')];
            icons.forEach(function(icon) {
                if (!icon) return;
                if (isDark) {
                    icon.classList.remove('fa-moon');
                    icon.classList.add('fa-sun');
                } else {
                    icon.classList.remove('fa-sun');
                    icon.classList.add('fa-moon');
                }
            });
        }

        function setDarkMode(isDark) {
            document.documentElement.classList.toggle('dark', isDark);
            localStorage.setItem('darkMode', isDark ? 'true' : 'false');
            updateIcons(isDark);
        }

        // Default: light mode. Only dark if explicitly saved as 'true'
        var saved = localStorage.getItem('darkMode');
        var isDark = saved === 'true';
        setDarkMode(isDark);

        // Toggle buttons
        document.getElementById('dark-mode-toggle')?.addEventListener('click', function() {
            setDarkMode(!document.documentElement.classList.contains('dark'));
        });
        document.getElementById('dark-mode-toggle-mobile')?.addEventListener('click', function() {
            setDarkMode(!document.documentElement.classList.contains('dark'));
        });
    })();
</script>